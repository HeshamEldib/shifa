.editorconfig: يساعد في الحفاظ على تنسيق كود موحد بين المحررات والـ IDEs المختلفة

https://editorconfig.org

سيكون هذا هو الملف الرئيسي

root = true

[*]

إعدادات عامة لجميع الملفات

charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.md]

إعدادات خاصة بملفات الماركدون

indent_size = 2
trim_trailing_whitespace = false

[*.json]

إعدادات خاصة بملفات جيسون

indent_size = 2